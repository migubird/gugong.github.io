      "achievements": [
        "太平天国",
        "英法联军"
      ]
    },
    {
      "id": "tongzhi",
      "name": "清穆宗载淳",
      "era_name": "同治",
      "reign_start": 1861,
      "reign_end": 1875,
      "description": "咸丰帝独子，六岁即位。两宫太后垂帘听政，平定太平天国，开启洋务运动。",
      "achievements": [
        "同治中兴",
        "垂帘听政"
      ]
    },
    {
      "id": "guangxu",
      "name": "清德宗载湉",
      "era_name": "光绪",
      "reign_start": 1875,
      "reign_end": 1908,
      "description": "清德宗，四岁登基，慈禧太后垂帘听政。亲政后发动戊戌变法，被慈禧镇压后遭软禁于瀛台。",
      "achievements": [
        "戊戌变法"
      ]
    },
    {
      "id": "xuantong",
      "name": "清逊帝溥仪",
      "era_name": "宣统",
      "reign_start": 1908,
      "reign_end": 1912,
