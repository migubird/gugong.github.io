{
  "ming_emperors": [
    {
      "id": "hongwu",
      "name": "明太祖朱元璋",
      "era_name": "洪武",
      "reign_start": 1368,
      "reign_end": 1398,
      "description": "明朝开国皇帝。推翻元朝建立明朝，定都南京。废除丞相制度，加强皇权。实行严刑峻法。",
      "achievements": [
        "建立明朝",
        "废除丞相",
        "编纂大明律"
      ]
    },
    {
      "id": "jianwen",
      "name": "明惠帝朱允炆",
      "era_name": "建文",
      "reign_start": 1398,
      "reign_end": 1402,
      "description": "朱元璋之孙，太子朱标之子。即位后削藩引发靖难之役，南京城破后下落不明。",
      "achievements": [
        "削藩政策"
      ]
    },
    {
      "id": "yongle",
      "name": "明成祖朱棣",
      "era_name": "永乐",
      "reign_start": 1402,
      "reign_end": 1424,
      "description": "明成祖，朱元璋第四子。通过靖难之役夺取皇位，迁都北京，修建紫禁城（1406-1420），派郑和下西洋，编《永乐大典》。",
      "achievements": [
        "修建故宫",
        "迁都北京",
        "郑和下西洋",
        "编纂永乐大典"
      ]
    },
    {
      "id": "hongxi",
      "name": "明仁宗朱高炽",
      "era_name": "洪熙",
      "reign_start": 1424,
      "reign_end": 1425,
      "description": "永乐帝长子。在位仅十个月，但废除苛政，为仁宣之治奠基。",
      "achievements": [
        "废除苛政",
        "仁宣之治奠基"
      ]
    },
    {
      "id": "xuande",
      "name": "明宣宗朱瞻基",
      "era_name": "宣德",
      "reign_start": 1425,
      "reign_end": 1435,
      "description": "与仁宗合称'仁宣之治'，明朝黄金时代。停止郑和下西洋，设内书堂教太监读书。",
      "achievements": [
        "仁宣之治",
        "停止下西洋"
      ]
    },
    {
      "id": "zhengtong",
      "name": "明英宗朱祁镇",
      "era_name": "正统",
      "reign_start": 1435,
      "reign_end": 1449,
      "description": "幼年即位，宠信王振。土木堡之变被瓦剌俘虏。后通过夺门之变复辟，改元天顺。",
      "achievements": [
        "土木堡之变",
        "夺门之变"
      ]
    },
    {
      "id": "jingtai",
      "name": "明代宗朱祁钰",
      "era_name": "景泰",
      "reign_start": 1449,
      "reign_end": 1457,
      "description": "英宗被俘后由大臣拥立即位，用于谦保卫北京。英宗复辟后被废为郕王。",
      "achievements": [
        "北京保卫战",
        "用于谦"
      ]
    },
    {
      "id": "chenghua",
      "name": "明宪宗朱见深",
      "era_name": "成化",
      "reign_start": 1464,
      "reign_end": 1487,
      "description": "英宗长子。早期励精图治，后期宠信万贵妃和宦官汪直。设立西厂。",
      "achievements": [
        "设立西厂"
      ]
    },
    {
      "id": "hongzhi",
      "name": "明孝宗朱祐樘",
      "era_name": "弘治",
      "reign_start": 1487,
      "reign_end": 1505,
      "description": "勤政爱民，驱逐奸佞，史称'弘治中兴'。一夫一妻制，仅张皇后一位配偶。",
      "achievements": [
        "弘治中兴"
      ]
    },
    {
      "id": "zhengde",
      "name": "明武宗朱厚照",
      "era_name": "正德",
      "reign_start": 1505,
      "reign_end": 1521,
      "description": "荒嬉无度，宠信宦官刘瑾（八虎）。自封威武大将军，豹房享乐。落水后病死无子。",
      "achievements": [
        "刘瑾专权",
        "应州大捷"
      ]
    },
    {
      "id": "jiajing",
      "name": "明世宗朱厚熜",
      "era_name": "嘉靖",
      "reign_start": 1521,
      "reign_end": 1566,
      "description": "明世宗，以藩王身份入继大统。前期励精图治，后期崇信道教，长期不上朝。严嵩专权，海瑞上疏。",
      "achievements": [
        "前期改革",
        "崇道修玄"
      ]
    },
    {
      "id": "longqing",
      "name": "明穆宗朱载坖",
      "era_name": "隆庆",
      "reign_start": 1521,
      "reign_end": 1567,
      "description": "嘉靖帝第三子。在位六年，任用高拱、张居正等，开启隆万大改革。",
      "achievements": [
        "隆万大改革",
        "俺答封贡"
      ]
    },
    {
      "id": "wanli",
      "name": "明神宗朱翊钧",
      "era_name": "万历",
      "reign_start": 1572,
      "reign_end": 1620,
      "description": "明神宗，张居正辅政前十余年励精图治，张居正死后长期怠政，二十八年不上朝。",
      "achievements": [
        "万历三大征",
        "张居正改革(前期)"
      ]
    },
    {
      "id": "taichang",
      "name": "明光宗朱常洛",
      "era_name": "泰昌",
      "reign_start": 1620,
      "reign_end": 1620,
      "description": "万历帝长子。在位仅一月，因红丸案暴亡。",
      "achievements": [
        "红丸案"
      ]
    },
    {
      "id": "tianqi",
      "name": "明熹宗朱由校",
      "era_name": "天启",
      "reign_start": 1620,
      "reign_end": 1627,
      "description": "光宗长子，木匠皇帝。宠信魏忠贤，阉党专权，东林党人遭迫害。",
      "achievements": [
        "魏忠贤专权",
        "东林党争"
      ]
    },
    {
      "id": "chongzhen",
      "name": "明思宗朱由检",
      "era_name": "崇祯",
      "reign_start": 1627,
      "reign_end": 1644,
      "description": "明朝最后一位皇帝。即位后铲除魏忠贤，但内忧外患不断，李自成攻破北京后自缢于煤山（景山）。",
      "achievements": [
        "铲除阉党"
      ]
    }
  ],
